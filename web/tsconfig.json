{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "isolatedModules": false,
        "strict": true,
        "types": [
            "node"
        ],
        "skipLibCheck": true
    },
    "include": [
        "**/*.ts"
    ]
}